# VITE_DOUBAO_API_KEY: Required for Doubao chat and image generation.
VITE_DOUBAO_API_KEY="ark-..."

# Optional: override the default Doubao chat model.
VITE_DOUBAO_CHAT_MODEL="doubao-seed-1-8-251228"

# Optional: override the default Doubao image model.
VITE_DOUBAO_IMAGE_MODEL="doubao-seedream-5-0-260128"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

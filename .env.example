# VITE_DOUBAO_API_KEY: Required for Doubao chat and image generation.
VITE_DOUBAO_API_KEY="ark-..."

# Optional: override the default Doubao chat model.
VITE_DOUBAO_CHAT_MODEL="doubao-seed-1-8-251228"

# Optional: override the default Doubao image model.
VITE_DOUBAO_IMAGE_MODEL="doubao-seedream-5-0-260128"

# Optional: enable Doubao video generation for AI视觉.
VITE_DOUBAO_VIDEO_MODEL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# Frontend proxy settings.
VITE_BACKEND_PROXY_PATH="/api/proxy"
VITE_ENABLE_BACKEND_PROXY="true"

# Server-only provider settings. Set real keys on the deployed Node service.
DOUBAO_API_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
DOUBAO_API_KEY=""
OPENROUTER_API_BASE_URL="https://singapore.zw-ai.com/api/v1/chat/completions"
OPENROUTER_API_KEY=""

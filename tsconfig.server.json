{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "express"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "server-dist",
    "rootDir": "."
  },
  "include": ["server/**/*.ts"],
  "exclude": ["node_modules", "dist", "server-dist"]
}
